# ============================================
# E-Tour 项目配置文件模板
# ============================================
# 使用方法：
# 1. 将此文件复制为 .env
# 2. 根据实际环境修改配置值
# 3. 确保 .gitignore 中包含 .env 文件

# ============================================
# 后端配置 (Spring Boot)
# ============================================

# 服务器配置
SERVER_PORT=8888
SERVER_CONTEXT_PATH=/api

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/etour?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# 阿里云OSS配置（可选）
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ENDPOINT_CNAME=
ALIYUN_OSS_ENDPOINT_INTERNAL=
ALIYUN_OSS_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIYUN_OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here
ALIYUN_OSS_BUCKET_NAME=your_bucket_name_here
ALIYUN_OSS_URL_PREFIX=
ALIYUN_OSS_URL_PREFIX_CNAME=
ALIYUN_OSS_URL_PREFIX_INTERNAL=

# ============================================
# Android端配置
# ============================================

# API基础URL - 根据开发环境选择
ANDROID_API_BASE_URL=http://10.0.2.2:8888/api/
ANDROID_API_LOCAL_URL=http://localhost:8888/api/
ANDROID_API_DEVICE_URL=http://your_local_ip:8888/api/
ANDROID_API_PROD_URL=https://your-domain.com/api/

# 高德地图API Key
# 申请地址：https://lbs.amap.com/
ANDROID_AMAP_API_KEY=your_amap_api_key_here

# ModelScope API配置（可选）
ANDROID_MODELSCOPE_API_KEY=your_modelscope_api_key_here
ANDROID_MODELSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ANDROID_MODELSCOPE_MODEL=qwen-turbo

# 本地AI服务配置（可选）
ANDROID_LOCAL_AI_SERVICE_URL=http://localhost:8080

# ============================================
# 前端配置 (Admin Web)
# ============================================

# API基础URL
VUE_APP_API_BASE_URL=http://localhost:8888/api

# ============================================
# 配置说明
# ============================================

# 数据库配置说明：
# - 确保已创建数据库 etour
# - MySQL版本要求：5.7+ 或 8.0+
# - 建议使用 UTF-8 字符集

# 高德地图API Key申请：
# 1. 访问 https://lbs.amap.com/
# 2. 注册账号并创建应用
# 3. 获取API Key
# 4. 将Key填入 ANDROID_AMAP_API_KEY

# ModelScope API Key申请：
# 1. 访问 https://modelscope.cn/
# 2. 注册账号并获取API Key
# 3. 将Key填入 ANDROID_MODELSCOPE_API_KEY

# 阿里云OSS配置说明：
# 1. 访问 https://oss.console.aliyun.com/
# 2. 创建Bucket
# 3. 获取Access Key ID和Access Key Secret
# 4. 配置相关参数
