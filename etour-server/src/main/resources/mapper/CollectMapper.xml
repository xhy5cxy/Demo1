<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.etour.mapper.CollectMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.etour.entity.Collect">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="strategy_id" property="strategyId" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, user_id, strategy_id, create_time
    </sql>
    
    <!-- 根据用户ID和攻略ID查询收藏记录 -->
    <select id="selectByUserIdAndStrategyId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM collect
        WHERE user_id = #{userId} AND strategy_id = #{strategyId}
        LIMIT 1
    </select>
    
    <!-- 根据用户ID查询收藏列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM collect
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据攻略ID查询收藏数量 -->
    <select id="selectCountByStrategyId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM collect
        WHERE strategy_id = #{strategyId}
    </select>
    
</mapper>