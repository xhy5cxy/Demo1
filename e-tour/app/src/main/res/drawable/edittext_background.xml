<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- 圆角 -->
    <corners android:radius="20dp" />
    
    <!-- 边框 -->
    <stroke 
        android:width="1dp"
        android:color="#E0E0E0" />
        
    <!-- 背景颜色 -->
    <solid android:color="#F5F5F5" />
    
    <!-- 内边距 -->
    <padding 
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
        
</shape>