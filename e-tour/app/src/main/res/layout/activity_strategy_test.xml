<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="攻略功能测试"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 测试按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <!-- 第一行按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_create_test_strategy"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="创建测试攻略"
                android:textSize="14sp"
                android:background="@drawable/button_primary_background"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_view_strategies"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="查看攻略列表"
                android:textSize="14sp"
                android:background="@drawable/button_secondary_background"
                android:textColor="#666666"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 第二行按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_clear_data"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="清空数据"
                android:textSize="14sp"
                android:background="@drawable/button_secondary_background"
                android:textColor="#666666"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_go_to_community"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="前往攻略广场"
                android:textSize="14sp"
                android:background="@drawable/button_primary_background"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 测试结果显示区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/test_result_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="点击上方按钮开始测试..."
            android:textSize="14sp"
            android:textColor="#666666"
            android:lineSpacingExtra="4dp" />
    </ScrollView>

    <!-- 底部说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="测试说明：\n1. 点击'创建测试攻略'生成测试数据\n2. 点击'前往攻略广场'查看显示效果\n3. 使用'查看攻略列表'验证数据存储\n4. 使用'清空数据'重置测试环境"
        android:textSize="12sp"
        android:textColor="#999999"
        android:lineSpacingExtra="2dp" />

</LinearLayout>