<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C6F3FF"
    android:id="@+id/main">

    <!-- 顶部 Have A Nice Trip + logo -->
    <androidx.cardview.widget.CardView
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp">

            <!-- Have A Nice Trip 卡片 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_subtle"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="欢迎来到etour"
                    android:textColor="#2D3748"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI旅行app"
                    android:textColor="#667eea"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- 飞机熊图片 -->
            <ImageView
                android:id="@+id/iv_plane_bear"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_logo"
                android:contentDescription="plane bear"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 新的智能导航按钮 - 更显眼的位置 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#667eea"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <Button
            android:id="@+id/btn_smart_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:enabled="true"
            android:longClickable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp"
            android:text="🚀 智能导航"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:importantForAccessibility="yes"
            android:contentDescription="点击启动智能导航服务" />

    </androidx.cardview.widget.CardView>

    <!-- 保留原按钮但隐藏，用于兼容性 -->
    <Button
        android:id="@+id/btn_amap_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/button_navigation_background"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:text="行程导航"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:translationZ="32dp"
        android:elevation="32dp"
        android:importantForAccessibility="no"
        android:contentDescription="点击启动地图导航"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />



    <!-- 待出发标题 -->
    <TextView
        android:id="@+id/tv_waiting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✈️ 待出发"
        android:textColor="#2D3748"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        android:letterSpacing="0.01"
        app:layout_constraintTop_toBottomOf="@id/card_navigation"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 行程卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/trip_card"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tv_waiting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="20dp">

             <!-- 左侧行程信息 -->
             <LinearLayout
                 android:layout_width="0dp"
                 android:layout_height="match_parent"
                 android:layout_weight="2"
                 android:orientation="vertical">

                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="🌶️ 赛博8D重庆三天两晚热辣滚烫之旅"
                     android:textColor="#2D3748"
                     android:textSize="18sp"
                     android:textStyle="bold"
                     android:letterSpacing="0.01"/>
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="📅 出发时间 待定"
                     android:textColor="#718096"
                     android:textSize="14sp"
                     android:layout_marginTop="6dp"/>
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="👥 共1名成员"
                     android:textColor="#718096"
                     android:textSize="14sp"
                     android:layout_marginTop="6dp"/>
             </LinearLayout>

             <!-- 右侧行程详情 -->
             <LinearLayout
                 android:layout_width="0dp"
                 android:layout_height="match_parent"
                 android:layout_weight="1"
                 android:orientation="vertical"
                 android:gravity="center"
                 android:paddingStart="16dp">

                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="✨ THE TRIP\nMUST GO ON"
                     android:textColor="#667eea"
                     android:textSize="12sp"
                     android:textStyle="bold"
                     android:textAlignment="center"/>
                 <View
                     android:layout_width="match_parent"
                     android:layout_height="1dp"
                     android:background="#667eea"
                     android:layout_marginVertical="8dp"/>
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="⏰ 时长：\n3天2晚"
                     android:textColor="#2D3748"
                     android:textSize="14sp"/>
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:text="📍 里程：\n约50.47KM"
                     android:textColor="#2D3748"
                     android:textSize="14sp"
                     android:layout_marginTop="6dp"/>
             </LinearLayout>
         </LinearLayout>
     </androidx.cardview.widget.CardView>

    <!-- 底部导航栏 -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 旅行之路按钮 -->
        <LinearLayout
            android:id="@+id/btn_travel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_travel"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_travel"/>

            <TextView
                android:id="@+id/tv_travel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="旅行之路"
                android:textColor="#B0B0B0"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 攻略广场按钮 -->
        <LinearLayout
            android:id="@+id/btn_explore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_explore"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_explore"/>

            <TextView
                android:id="@+id/tv_explore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="攻略广场"
                android:textColor="#B0B0B0"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 中间圆形加号按钮 -->
        <FrameLayout
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/circle_add_background"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:tint="#FFFFFF"/>
            </LinearLayout>
        </FrameLayout>

        <!-- AI助手按钮 -->
        <LinearLayout
            android:id="@+id/btn_ai"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_ai"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_ai"/>

            <TextView
                android:id="@+id/tv_ai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI助手"
                android:textColor="#B0B0B0"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- 我的按钮 -->
        <LinearLayout
            android:id="@+id/btn_me"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_me"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_me"/>

            <TextView
                android:id="@+id/tv_me"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textColor="#B0B0B0"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>