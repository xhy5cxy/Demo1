# ============================================
# E-Tour .gitignore 文件
# ============================================

# ============================================
# 私人配置文件
# ============================================
.env
.env.local
.env.*.local

# ============================================
# Android端忽略文件
# ============================================
android-client/.idea/
android-client/.gradle/
android-client/local.properties
android-client/gradle.properties
android-client/gradlew
android-client/gradlew.bat
android-client/app/build/
android-client/build/
android-client/*.iml
android-client/spotless.gradle
android-client/spotless.gradle.kts

# ============================================
# 后端忽略文件 (Spring Boot)
# ============================================
etour-server/.idea/
etour-server/build/
etour-server/target/
etour-server/.gradle/
etour-server/gradlew
etour-server/gradlew.bat
etour-server/gradle.properties
etour-server/logs/
etour-server/uploads/
etour-server/*.iml
etour-server/out/

# ============================================
# 前端忽略文件 (Vue.js)
# ============================================
admin-web/node_modules/
admin-web/dist/
admin-web/.env
admin-web/.env.local
admin-web/.npmrc
admin-web/package-lock.json
admin-web/yarn.lock
admin-web/.idea/
admin-web/.vscode/
admin-web/*.log

# ============================================
# 通用忽略文件
# ============================================
*.log
*.tmp
*.temp
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================
# 数据库备份文件
# ============================================
*.sql
*.sql.gz
*.sql.bak
*_backup_*.sql

# 保留docs目录下的数据库文件
!docs/database/*.sql

# Android签名密钥
android-client/my-release-key.keystore

# ============================================
# IDE配置文件
# ============================================
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ============================================
# 构建产物
# ============================================
build/
target/
dist/
out/
